// Koma — Prisma Schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── MODELOS ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String?  @map("password_hash")
  googleId     String?  @unique @map("google_id")
  avatarUrl    String?  @map("avatar_url")
  language     String   @default("es") @map("language")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  userComics   UserComic[]
  collections  Collection[]

  @@map("users")
}

// Volumen / Cómic — registro canónico, inmutable tras creación salvo por su creador
model Comic {
  id           String         @id @default(cuid())
  title        String
  issueNumber  String?        @map("issue_number")
  publisher    String?
  year         Int?
  synopsis     String?        @db.Text
  coverUrl     String?        @map("cover_url")
  isbn         String         @unique               // obligatorio, no editable
  binding      BindingFormat?
  drawingStyle String?        @map("drawing_style")
  authors      String?
  scriptwriter String?
  artist       String?
  // null = importado desde ISBNdb; userId = creado manualmente por ese usuario
  createdBy    String?        @map("created_by")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  userComics   UserComic[]
  tags         ComicTag[]

  @@map("comics")
}

// Tabla pivote: relación Usuario ↔ Cómic con estado personalizado
// Grupo 1 (collectionStatus) y Grupo 3 (saleStatus) tienen exclusión cruzada:
//   SOLD → collectionStatus = null (ya no está en posesión del usuario)
//   FOR_SALE / TO_SELL son compatibles con IN_COLLECTION o LOANED
model UserComic {
  id               String            @id @default(cuid())
  // Grupo 1 — Estado de colección (excluyente con SOLD del grupo 3)
  collectionStatus CollectionStatus? @map("collection_status")
  // Grupo 2 — Estado de lectura
  readStatus       ReadStatus?       @map("read_status")
  // Grupo 3 — Estado de venta/mercadillo
  saleStatus       SaleStatus?       @map("sale_status")
  // Campo de apoyo para LOANED
  loanedTo         String?           @map("loaned_to")
  rating           Int?                        // 1-5, null si no ha puntuado
  notes            String?           @db.Text
  addedAt          DateTime          @default(now()) @map("added_at")
  seriesPosition   Int?              @map("series_position")
  // Serie a la que el usuario asigna este cómic (per-user, no global)
  collectionSeriesId String?           @map("collection_series_id")
  collectionSeries   CollectionSeries? @relation(fields: [collectionSeriesId], references: [id], onDelete: SetNull)

  override  UserComicOverride?

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String @map("user_id")
  comic     Comic  @relation(fields: [comicId], references: [id], onDelete: Cascade)
  comicId   String @map("comic_id")

  @@unique([userId, comicId])
  @@map("user_comics")
}

enum BindingFormat {
  CARTONE
  TAPA_BLANDA
  BOLSILLO
  OMNIBUS
  HARDCOVER
  SOFTCOVER
  DIGITAL
  OTHER
}

// ─── Enums de estado UserComic ─────────────────────────────────────────────────

// Group 1: Ownership status (mutually exclusive)
enum CollectionStatus {
  IN_COLLECTION
  WISHLIST
  LOANED
}

// Group 2: Reading status (mutually exclusive)
enum ReadStatus {
  READ
  READING
  TO_READ
}

// Group 3: Sale/marketplace status (mutually exclusive)
// SOLD implies collectionStatus = null
enum SaleStatus {
  FOR_SALE
  TO_SELL
  SOLD
}

// Colección temática del usuario (ej: "Mi colección de Astérix")
// Siempre tiene al menos una Serie "Principal" creada automáticamente
model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  isPublic    Boolean  @default(false) @map("is_public")
  rating      Int?
  createdAt   DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")
  series CollectionSeries[]

  @@map("collections")
}

// Serie dentro de una Colección (ej: "Principal", "Edición Deluxe")
// totalVolumes = número de volúmenes esperados en esta serie
model CollectionSeries {
  id           String     @id @default(cuid())
  name         String
  isDefault    Boolean    @default(false) @map("is_default")
  position     Int        @default(0)
  totalVolumes Int?       @map("total_volumes")
  createdAt    DateTime   @default(now()) @map("created_at")

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId String     @map("collection_id")
  userComics   UserComic[]

  @@map("collection_series")
}

// Tags para categorizar cómics (asignados por el agente IA o manualmente)
model Tag {
  id     String     @id @default(cuid())
  name   String     @unique
  slug   String     @unique

  comics ComicTag[]

  @@map("tags")
}

// Overrides personales por usuario para un UserComic concreto.
// Toman prioridad sobre el registro canónico Comic al mostrar datos.
// Solo aplican a usuarios que NO son el creador del cómic (comic.createdBy).
model UserComicOverride {
  id          String    @id @default(cuid())
  userComicId String    @unique @map("user_comic_id")
  userComic   UserComic @relation(fields: [userComicId], references: [id], onDelete: Cascade)

  title        String?
  issueNumber  String?        @map("issue_number")
  publisher    String?
  year         Int?
  synopsis     String?        @db.Text
  coverUrl     String?        @map("cover_url")
  binding      BindingFormat?
  drawingStyle String?        @map("drawing_style")
  authors      String?
  scriptwriter String?
  artist       String?

  @@map("user_comic_overrides")
}

// Relación M:N entre Comic y Tag
model ComicTag {
  comic   Comic  @relation(fields: [comicId], references: [id], onDelete: Cascade)
  comicId String @map("comic_id")
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId   String @map("tag_id")

  @@id([comicId, tagId])
  @@map("comic_tags")
}
