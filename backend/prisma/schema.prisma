// Koma — Prisma Schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── MODELOS ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String?  @map("password_hash")
  googleId     String?  @unique @map("google_id")
  avatarUrl    String?  @map("avatar_url")
  language     String   @default("es") @map("language")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  userComics   UserComic[]
  collections  Collection[]

  @@map("users")
}

// Serie como entidad propia — agrupa issues y permite tracking de completitud
model Series {
  id          String   @id @default(cuid())
  name        String
  publisher   String?
  yearBegan   Int?     @map("year_began")
  yearEnded   Int?     @map("year_ended")
  totalIssues Int?     @map("total_issues")
  // ID de la serie en GCD (gcd_series.id) — null si no viene de GCD
  gcdSeriesId    Int?     @unique @map("gcd_series_id")
  // URL de la colección en Tebeosfera — null si no viene de Tebeosfera
  tebeosferaUrl  String?  @unique @map("tebeosfera_url")
  // Portada representativa (la del primer issue importado, o manual)
  coverUrl    String?  @map("cover_url")
  isOngoing   Boolean  @default(true) @map("is_ongoing")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  comics      Comic[]

  @@map("series")
}

model Comic {
  id           String         @id @default(cuid())
  title        String
  issueNumber  String?        @map("issue_number")
  publisher    String?
  year         Int?
  synopsis     String?        @db.Text
  coverUrl     String?        @map("cover_url")
  // ID del cómic en la API externa (Comic Vine, Marvel, etc.)
  externalId   String?        @map("external_id")
  externalApi  String?        @map("external_api") // "gcd" | "google_books" | "open_library" | "isbndb"
  // Metadatos variables de APIs externas guardados como JSON
  metadata     Json?
  // Campos de coleccionista
  isbn         String?
  binding      BindingFormat?
  drawingStyle String?        @map("drawing_style")
  authors      String?
  // Nombre de serie denormalizado (fallback para cómics sin FK a Series)
  series       String?
  // Relación con entidad Series (nullable — cómics importados antes de la migración no la tienen)
  seriesId     String?        @map("series_id")
  seriesRef    Series?        @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  // Phantom: cómic creado desde Tebeosfera con datos mínimos, pendiente de enriquecer con ISBN
  isPhantom    Boolean        @default(false) @map("is_phantom")
  tebeosferaUrl String?       @map("tebeosfera_url") // URL del número en Tebeosfera
  // Estado del lookup automático de serie en Tebeosfera: pending | found | not_found | error | null
  tebeosferaStatus String?    @map("tebeosfera_status")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  userComics   UserComic[]
  tags         ComicTag[]
  collections  CollectionComic[]

  @@map("comics")
}

// Tabla pivote: relación Usuario ↔ Cómic con estado personalizado
model UserComic {
  id         String   @id @default(cuid())
  // Estados múltiples simultáneos (un cómic puede ser TENGO + LEÍDO + FAVORITO a la vez)
  isOwned    Boolean  @default(false) @map("is_owned")
  isRead     Boolean  @default(false) @map("is_read")
  isWishlist Boolean  @default(false) @map("is_wishlist")
  isFavorite Boolean  @default(false) @map("is_favorite")
  // Préstamos
  isLoaned   Boolean  @default(false) @map("is_loaned")
  loanedTo   String?  @map("loaned_to")
  rating     Int?                     // 1-5, null si no ha puntuado
  notes      String?  @db.Text
  addedAt    DateTime @default(now()) @map("added_at")

  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String @map("user_id")
  comic     Comic  @relation(fields: [comicId], references: [id], onDelete: Cascade)
  comicId   String @map("comic_id")

  // Un usuario no puede tener el mismo cómic duplicado en su colección
  @@unique([userId, comicId])
  @@map("user_comics")
}

enum BindingFormat {
  CARTONE
  TAPA_BLANDA
  BOLSILLO
  OMNIBUS
  HARDCOVER
}

// Colecciones temáticas creadas por el usuario (ej: "Mi colección de Batman")
model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  isPublic    Boolean  @default(false) @map("is_public")
  rating      Int?     // 1-5 estrellas
  createdAt   DateTime @default(now()) @map("created_at")

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String  @map("user_id")
  comics      CollectionComic[]

  @@map("collections")
}

// Relación M:N entre Collection y Comic
model CollectionComic {
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId String     @map("collection_id")
  comic        Comic      @relation(fields: [comicId], references: [id], onDelete: Cascade)
  comicId      String     @map("comic_id")
  addedAt      DateTime   @default(now()) @map("added_at")
  position     Int?       // Orden manual del usuario dentro de la colección (1 = primero)

  @@id([collectionId, comicId])
  @@map("collection_comics")
}

// Tags para categorizar cómics (ej: "superhéroe", "noir", "dc-universe")
// El agente IA los asignará automáticamente basándose en la sinopsis
model Tag {
  id     String     @id @default(cuid())
  name   String     @unique
  slug   String     @unique // "super-heroe", "noir"

  comics ComicTag[]

  @@map("tags")
}

// Relación M:N entre Comic y Tag
model ComicTag {
  comic   Comic  @relation(fields: [comicId], references: [id], onDelete: Cascade)
  comicId String @map("comic_id")
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId   String @map("tag_id")

  @@id([comicId, tagId])
  @@map("comic_tags")
}
