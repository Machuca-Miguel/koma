# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/comicvault?sslmode=require"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Genera un secreto: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="CAMBIA_ESTO_POR_UN_SECRETO_ALEATORIO_LARGO"
JWT_EXPIRES_IN="7d"

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"

# ─── IA (Anthropic) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── APIs EXTERNAS ────────────────────────────────────────────────────────────
COMIC_VINE_API_KEY=""
METRON_USERNAME=""
METRON_PASSWORD=""
