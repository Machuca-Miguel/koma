# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/Koma?sslmode=require"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Genera un secreto: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="CAMBIA_ESTO_POR_UN_SECRETO_ALEATORIO_LARGO"
JWT_EXPIRES_IN="7d"

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="development"

# ─── GOOGLE BOOKS ─────────────────────────────────────────────────────────────
# Sin key: 1000 req/día. Con key (console.cloud.google.com → Books API): 10.000/día
GOOGLE_BOOKS_API_KEY=""

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"
FRONTEND_URL="http://localhost:5173"

# ─── IA (Anthropic) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── APIs EXTERNAS ────────────────────────────────────────────────────────────
COMIC_VINE_API_KEY=""
METRON_USERNAME=""
METRON_PASSWORD=""

# ─── ISBNDB ───────────────────────────────────────────────────────────────────
# Obtén tu key en https://isbndb.com/isbn-database-api
# Plan Basic ($14.99/mes): 5.000 búsquedas/día, 1 req/s, 100 resultados/llamada
ISBNDB_API_KEY=""
